javascript\par
\par
document.querySelectorAll('a[href^="#"]').forEach(link=>\{\par
  link.addEventListener('click',e=>\{\par
    const target=document.querySelector(link.getAttribute('href'));\par
    if(target)\{\par
      e.preventDefault();\par
      target.scrollIntoView(\{behavior:'smooth',block:'start'\});\par
    \}\par
  \});\par
\});\f0\par
}
