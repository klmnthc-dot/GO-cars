css

:root{
  --bg:#07111f;
  --panel:#0c1728;
  --text:#f4f7fb;
  --muted:#b7c4d8;
  --blue:#1d4ed8;
  --red:#dc2626;
  --line:rgba(255,255,255,.12);
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;font-family:'Inter',sans-serif;background:radial-gradient(circle at top left,#10213d 0,#07111f 45%,#050b14 100%);color:var(--text)}
a{color:inherit;text-decoration:none}
.hero{min-height:100vh;padding:20px 18px 40px}
.nav,.hero-content,.info-grid{max-width:1180px;margin:0 auto}
.nav{display:flex;justify-content:space-between;align-items:center;padding:8px 0 28px}
.brand{display:flex;align-items:baseline;gap:8px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
.brand-mark{color:#fff;font-size:1.35rem}
.brand-text{color:#7dd3fc}
.nav-link{padding:10px 16px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.04)}
.hero-content{display:grid;grid-template-columns:1.1fr .9fr;gap:36px;align-items:center}
.eyebrow{color:#8fb5ff;text-transform:uppercase;letter-spacing:.16em;font-size:.78rem}
h1{font-size:clamp(2.6rem,6vw,5.4rem);line-height:.95;margin:14px 0 18px;max-width:12ch}
.lead{color:var(--muted);font-size:1.08rem;line-height:1.7;max-width:58ch}
.cta-row{display:flex;flex-wrap:wrap;gap:14px;margin:28px 0}
.btn{display:inline-flex;align-items:center;justify-content:center;padding:14px 22px;border-radius:14px;font-weight:700;border:1px solid transparent;transition:.2s ease;box-shadow:0 10px 30px rgba(0,0,0,.25)}
.btn:hover{transform:translateY(-2px)}
.btn-primary{background:linear-gradient(135deg,var(--blue),#2563eb)}
.btn-secondary{background:rgba(255,255,255,.05);border-color:var(--line)}
.contact-card{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;padding:18px;border:1px solid var(--line);border-radius:22px;background:rgba(255,255,255,.04);backdrop-filter:blur(12px)}
.label{display:block;color:var(--muted);font-size:.8rem;margin-bottom:6px}
.contact-card a{font-weight:700}
.hero-visual{position:relative;min-height:520px;display:flex;align-items:center;justify-content:center}
.glow{position:absolute;width:260px;height:260px;border-radius:50%;filter:blur(25px);opacity:.55}
.glow-blue{background:rgba(29,78,216,.65);top:12%;left:8%}
.glow-red{background:rgba(220,38,38,.55);bottom:8%;right:12%}
.car-card{position:relative;z-index:1;width:min(100%,430px);padding:30px;border-radius:28px;background:linear-gradient(180deg,rgba(12,23,40,.94),rgba(7,17,31,.94));border:1px solid var(--line);box-shadow:0 30px 80px rgba(0,0,0,.45)}
.card-top,.badge{display:inline-block;font-size:.8rem;letter-spacing:.12em;text-transform:uppercase}
.card-top{color:#93c5fd}
.car-card h2{font-size:2rem;margin:12px 0 18px}
.car-card ul{margin:0;padding-left:18px;color:var(--muted);line-height:1.9}
.badge{margin-top:22px;padding:10px 14px;border-radius:999px;background:rgba(220,38,38,.14);border:1px solid rgba(220,38,38,.3);color:#fecaca}
.info-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px;margin-top:-18px;padding-bottom:40px}
.info-grid article{padding:24px;border-radius:22px;background:rgba(255,255,255,.04);border:1px solid var(--line)}
.info-grid h3{margin-top:0}
.info-grid p{color:var(--muted);line-height:1.7}
@media (max-width:900px){.hero-content,.info-grid{grid-template-columns:1fr}.hero-visual{min-height:380px}.nav{padding-bottom:18px}}
@media (max-width:640px){.hero{padding:16px 14px 30px}.contact-card{grid-template-columns:1fr}.cta-row{flex-direction:column}.btn{width:100%}.hero-visual{min-height:320px}.car-card{padding:22px}.info-grid{margin-top:0}}

javascript

document.querySelectorAll('a[href^="#"]').forEach(link=>{
  link.addEventListener('click',e=>{
    const target=document.querySelector(link.getAttribute('href'));
    if(target){
      e.preventDefault();
      target.scrollIntoView({behavior:'smooth',block:'start'});
    }
  });
});
